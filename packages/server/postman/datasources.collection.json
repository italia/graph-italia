{
  "info": {
    "name": "Graph Italia — Data Sources",
    "_postman_id": "graph-italia-datasources",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{api_key}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3003/api" },
    { "key": "api_key",  "value": "dv_replace_with_your_key" }
  ],
  "item": [
    {
      "name": "List data sources",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/datasources", "host": ["{{base_url}}"], "path": ["datasources"] }
      }
    },
    {
      "name": "Get data source by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}"]
        }
      }
    },
    {
      "name": "Create data source (inline)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/datasources", "host": ["{{base_url}}"], "path": ["datasources"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sales Data\",\n  \"description\": \"Monthly sales figures\",\n  \"data\": [\n    { \"month\": \"Jan\", \"value\": 100 },\n    { \"month\": \"Feb\", \"value\": 150 }\n  ],\n  \"publish\": false,\n  \"isTrasposed\": false\n}"
        }
      }
    },
    {
      "name": "Create data source (remote URL)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/datasources", "host": ["{{base_url}}"], "path": ["datasources"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Remote CSV\",\n  \"data\": [],\n  \"isRemote\": true,\n  \"remoteUrl\": \"https://example.com/data.csv\"\n}"
        }
      }
    },
    {
      "name": "Update data source",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}"]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Source\",\n  \"publish\": true\n}"
        }
      }
    },
    {
      "name": "Delete data source",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}"]
        }
      }
    },
    {
      "name": "List chart links",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}/links",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}", "links"]
        }
      }
    },
    {
      "name": "Link chart to data source",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}/links",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}", "links"]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"chartId\": \"{{chart_id}}\",\n  \"config\": {}\n}"
        }
      }
    },
    {
      "name": "Unlink chart from data source",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/datasources/{{datasource_id}}/links/{{chart_id}}",
          "host": ["{{base_url}}"],
          "path": ["datasources", "{{datasource_id}}", "links", "{{chart_id}}"]
        }
      }
    }
  ]
}
