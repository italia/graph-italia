VITE_SERVER_URL="http://127.0.0.1:3003"

# Toggles public chart/dashboard publishing (public "publish" flag, /display/*, /embed/*).
# Set to "false" to disable public sharing entirely: the publish toggle is hidden
# in the editors (and always saved as false), embed routes show a disabled notice,
# and display/show routes become an authenticated-only preview instead of a public page.
VITE_ENABLE_PUBLIC_PUBLISHING="true"