{
  "name": "dataviz",
  "private": "false",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:webapp & bun run dev:server",
    "dev:webapp": "bun run --elide-lines=0 --filter dataviz-webapp dev",
    "dev:server": "bun run --elide-lines=0 --filter dataviz-server dev",
    "dev:components": "bun run --elide-lines=0 --filter dataviz-components dev",
    "build": "bun run --filter '*' build",
    "build:webapp": "bun run --elide-lines=0 --filter dataviz-webapp build",
    "build:components": "bun run --elide-lines=0 --filter dataviz-components build",
    "clean": "rm -rf node_modules packages/app/node_modules packages/server/node_modules bun.lockb packages/app/bun.lockb packages/bserver/bun.lockb",
    "seed": "bun run packages/server/seeds/seed-users"
  },
  "devDependencies": {
    "bun-types": "1.3.2"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "react-data-table-component": "^7.7.0"
  }
}
